entity_detail:
  tag: VCB
  type: breaker
  name: 진공 차단기
  specs: {}
  drawing_texts:
  - source: page_002_context.yaml
    page_number: 2
    text: '6.6kV 변전설비 단선결선도로, R-Center 변전실 신설분과 A동 지하1층 변전실 이설분이 함께 표시되어 있다.


      주요 설비는 TR #1~#3, TR-3204, IVR 1/2, GIPAM/GIMAC, VCB/ACB/MCCB, CT/PT/ZCT/GPT,
      BATTERY/RECTIFIER/CAPACITOR,

      각종 HV/LV 피더 및 패널이다.


      표기된 주요 용량은 TR #1 2,000kVA, TR #2 2,000kVA, TR #3 2,000kVA, TR-3204 1,000kVA,
      IVR 1 1,500kVA, IVR 2 300kVA이다.'
  - source: page_002_context.yaml
    page_number: 2
    text: 진공차단기
  requirements: []
  connection_specs: []
  ontology_hints:
    observed_relations:
    - relation_type: appears_in
      partner_tag: R-Center 변전실
      direction: within
      source: page_002_context.yaml
    - relation_type: appears_with
      partner_tag: GIPAM
      direction: same_page
      source: page_002_context.yaml
    - relation_type: appears_with
      partner_tag: GIMAC
      direction: same_page
      source: page_002_context.yaml
    - relation_type: appears_with
      partner_tag: ACB
      direction: same_page
